<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane fx:id="mainBorderPane" styleClass="kernel-root" stylesheets="@../styles/kernel_warm.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.syncron.controllers.MainController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" styleClass="kernel-header">
            <Label text="KERNEL" style="-fx-font-family: 'Georgia', serif; -fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #8A3B2B; -fx-letter-spacing: 1px;"/>
            <Circle radius="3.0" fill="#8C7A6B" />
            <Label text="CSE - BUET" style="-fx-font-family: 'Inter', sans-serif; -fx-font-size: 14px; -fx-text-fill: #8C7A6B;"/>

            <Region HBox.hgrow="ALWAYS" />

            <Button text="🔔" styleClass="kernel-notification-btn" />
            <HBox fx:id="profileBtn" alignment="CENTER" spacing="10" styleClass="kernel-profile-box" style="-fx-cursor: hand;">
                <Label text="Profile" style="-fx-font-family: 'Inter', sans-serif; -fx-font-weight: bold; -fx-text-fill: #4A2C1A;" />
                <Circle radius="12.0" fill="#A0522D" />
            </HBox>
        </HBox>
    </top>

    <left>
        <VBox fx:id="sidebar" styleClass="kernel-course-sidebar" prefWidth="220" spacing="5">
            <VBox fx:id="sidebarButtonContainer" spacing="2">
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox style="-fx-background-color: #FFFCF8; -fx-padding: 30 40 30 40;" spacing="15">

            <HBox fx:id="breadcrumbBar" alignment="CENTER_LEFT" spacing="5" />

            <VBox fx:id="courseHeaderBox">
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <Label fx:id="courseHeaderLabel" style="-fx-font-family: 'Georgia', serif; -fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #4A2C1A;" />
                    <Label fx:id="creditsFlair" styleClass="course-badge-warm" />
                    <Label fx:id="courseTypeFlair" styleClass="course-badge-warm" />
                </HBox>
            </VBox>

            <StackPane fx:id="contentArea" VBox.vgrow="ALWAYS">
                <padding><Insets top="10"/></padding>
            </StackPane>
        </VBox>
    </center>

</BorderPane>