<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<ScrollPane fitToWidth="true" styleClass="kernel-root" stylesheets="@../styles/kernel_warm.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.syncron.controllers.HomeController">
    <content>
        <VBox spacing="25.0" styleClass="kernel-content">
            <padding>
                <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
            </padding>
            <children>

                <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="kernel-header" style="-fx-background-color: transparent; -fx-border-width: 0;">
                    <children>
                        <Label text="KERNEL" style="-fx-font-family: 'Georgia', serif; -fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #8A3B2B; -fx-letter-spacing: 1px;" />
                        <Circle radius="3.0" fill="#8C7A6B" />
                        <Label text="CSE - BUET" style="-fx-font-family: 'Inter', sans-serif; -fx-font-size: 14px; -fx-text-fill: #8C7A6B;" />

                        <Region HBox.hgrow="ALWAYS" />

                        <Button text="🔔" styleClass="kernel-notification-btn" />
                        <HBox fx:id="profileBtn" alignment="CENTER" spacing="10" styleClass="kernel-profile-box" style="-fx-cursor: hand;">
                            <Label text="Ahnaf Ahmed Shafi" style="-fx-font-family: 'Inter', sans-serif; -fx-font-weight: bold; -fx-text-fill: #4A2C1A;" />
                            <Circle radius="12.0" fill="#A0522D" />
                        </HBox>
                    </children>
                </HBox>

                <VBox spacing="10.0" styleClass="kernel-semester-card">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Label text="Semester : July 2025" styleClass="kernel-semester-title" />
                            <Label text="PRESENT" styleClass="kernel-semester-pill" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Button fx:id="detailsBtn" text="See Semester Details →" style="-fx-background-color: transparent; -fx-text-fill: #A0522D; -fx-font-family: 'Inter', sans-serif; -fx-cursor: hand;" />
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                            <ProgressBar fx:id="semesterProgressBar" progress="0.65" prefHeight="10.0" maxWidth="Infinity" HBox.hgrow="ALWAYS" style="-fx-accent: #2ECC71;" />
                            <Label text="65% Completed" style="-fx-text-fill: #8C7A6B; -fx-font-family: 'Inter', sans-serif; -fx-font-size: 12px;" />
                        </HBox>

                        <HBox spacing="20.0" style="-fx-padding: 10 0 0 0;">
                            <Label text="📅 Term Final: 12 Oct 2025" style="-fx-text-fill: #8C7A6B; -fx-font-family: 'Inter', sans-serif; -fx-font-size: 13px;" />
                            <Label text="⏳ Days Remaining: 45" style="-fx-text-fill: #E74C3C; -fx-font-family: 'Inter', sans-serif; -fx-font-weight: bold; -fx-font-size: 13px;" />
                        </HBox>
                    </children>
                </VBox>

                <Label text="Welcome Back, Shafi!" style="-fx-font-family: 'Georgia', serif; -fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #4A2C1A; -fx-padding: 10 0 5 0;" />

                <HBox spacing="25.0">
                    <children>

                        <VBox prefWidth="260.0" spacing="20.0">
                            <VBox spacing="10" styleClass="kernel-pinned-box">
                                <Label text="📌 Pinned Items" styleClass="kernel-pinned-title" />
                                <Label text="• Academic Calendar" styleClass="kernel-pinned-link" />
                                <Label text="• Exam Routine" styleClass="kernel-pinned-link" />
                            </VBox>

                            <VBox fx:id="urgentContainer" spacing="10" styleClass="kernel-pinned-box">
                                <Label text="🔥 Upcoming" styleClass="kernel-accent-text" />
                            </VBox>
                        </VBox>

                        <VBox HBox.hgrow="ALWAYS" spacing="15.0">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="Course Overview" styleClass="kernel-section-header" />
                                <Region HBox.hgrow="ALWAYS" />
                                <TextField promptText="Search courses..." style="-fx-background-radius: 15; -fx-background-color: #FFFCF8; -fx-border-color: #E0D5C7; -fx-border-radius: 15; -fx-font-family: 'Inter', sans-serif;" />
                            </HBox>

                            <VBox fx:id="courseCardContainer" spacing="15.0">
                            </VBox>
                        </VBox>

                        <VBox prefWidth="260.0" spacing="20.0">
                            <VBox spacing="10" styleClass="kernel-pinned-box">
                                <Label text="🕒 Recently Accessed" styleClass="kernel-pinned-title" />
                                <Label text="• CSE 108 Syllabus" styleClass="kernel-pinned-link" />
                                <Label text="• Week 12 Project" styleClass="kernel-pinned-link" />
                            </VBox>
                        </VBox>

                    </children>
                </HBox>

            </children>
        </VBox>
    </content>
</ScrollPane>