<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" styleClass="kernel-scroll"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.syncron.controllers.TeacherHomeController">
    <content>
        <VBox spacing="25.0" style="-fx-background-color: #FAF6F1;">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0"/>
            </padding>

            <!-- Welcome Message -->
            <Label text="Welcome Back, Professor!" styleClass="kernel-welcome"
                   style="-fx-padding: 10 0 5 0;"/>

            <!-- Main Content: Sidebar + Courses -->
            <HBox spacing="25.0">

                <!-- Left Sidebar: Pinned Items -->
                <VBox prefWidth="240.0" spacing="20.0">
                    <!-- Pinned Items -->
                    <VBox spacing="10" styleClass="kernel-pinned-box">
                        <Label text="📌 Pinned Items" styleClass="kernel-pinned-title"/>
                        <Label text="• Academic Calendar" styleClass="kernel-pinned-link"/>
                        <Label text="• Exam Routine" styleClass="kernel-pinned-link"/>
                    </VBox>

                    <!-- Quick Stats -->
                    <VBox spacing="10" styleClass="kernel-pinned-box">
                        <Label text="📊 Quick Stats" styleClass="kernel-pinned-title"/>
                        <Label text="Active Courses: 3" style="-fx-text-fill: #4A2C1A; -fx-font-size: 13px;"/>
                        <Label text="Pending Reviews: 5" style="-fx-text-fill: #A0522D; -fx-font-size: 13px;"/>
                    </VBox>
                </VBox>

                <!-- Right: Course Overview -->
                <VBox HBox.hgrow="ALWAYS" spacing="15.0">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="Course Overview" styleClass="kernel-section-header"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <TextField promptText="Search courses..."
                                   style="-fx-background-radius: 15; -fx-background-color: #FFFCF8; -fx-border-color: #E0D5C7; -fx-border-radius: 15;"/>
                    </HBox>

                    <!-- Course Cards Container (populated by controller) -->
                    <VBox fx:id="courseCardContainer" spacing="15.0">

                        <!-- Static Example Cards -->

                        <!-- Card: CSE 105 -->
                        <HBox spacing="10" styleClass="kernel-course-card">
                            <VBox>
                                <Label text="CSE 105" styleClass="kernel-course-code"/>
                                <Label text="Discrete Mathematics" styleClass="kernel-course-title"/>
                            </VBox>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="➜" styleClass="kernel-course-arrow"
                                   style="-fx-alignment: CENTER;"/>
                        </HBox>

                        <!-- Card: CSE 107 -->
                        <HBox spacing="10" styleClass="kernel-course-card">
                            <VBox>
                                <Label text="CSE 107" styleClass="kernel-course-code"/>
                                <Label text="Discrete Mathematics Sessional" styleClass="kernel-course-title"/>
                            </VBox>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="➜" styleClass="kernel-course-arrow"
                                   style="-fx-alignment: CENTER;"/>
                        </HBox>

                    </VBox>
                </VBox>

            </HBox>

        </VBox>
    </content>
</ScrollPane>
